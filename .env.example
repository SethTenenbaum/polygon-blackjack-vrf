# Polygon Amoy Testnet RPC URL
# Get from: https://www.alchemy.com/ or https://infura.io/
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY

# Your wallet private key (without 0x prefix)
# ⚠️ NEVER commit this to git! Keep it secret!
PRIVATE_KEY=your_private_key_here

# Etherscan API key for contract verification (optional)
# Get from: https://polygonscan.com/apis (same key works for Etherscan/Polygonscan)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Contract addresses (filled in after deployment)
GAME_FACTORY_ADDRESS=
GAME_FACTORY_UPGRADEABLE_ADDRESS=
PROXY_ADDRESS=
